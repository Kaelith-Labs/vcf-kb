{
  "name": "@vcf/kb",
  "version": "0.0.1-alpha.0",
  "description": "Vibe Coding Framework knowledge base — primers, best-practices, lenses, review stages, reviewer configs. Content-only, no runtime code.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Vibe Coding Framework contributors",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "kb",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "validate": "vitest run && npm run validate:kb && npm run port:check",
    "validate:kb": "tsx scripts/validate-kb.ts",
    "port": "tsx scripts/port-kb.ts",
    "port:check": "tsx scripts/port-kb.ts --check",
    "typecheck": "tsc --noEmit",
    "lint": "prettier --check --no-error-on-unmatched-pattern \"kb/**/*.md\"",
    "lint:fix": "prettier --write --no-error-on-unmatched-pattern \"kb/**/*.md\""
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "gray-matter": "^4.0.3",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "zod": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
